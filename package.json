{
  "name": "lab21-ui-kit",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run build:core && npm run build:wrappers && vite --port=3000 --host=0.0.0.0",
    "build": "npm run build:core && npm run build:wrappers && vite build",
    "preview": "vite preview",
    "build:core": "npm run build --workspace @lab21/core",
    "build:wrappers": "npm run build --workspace @lab21/react && npm run build --workspace @lab21/vue",
    "clean": "rm -rf dist server.js packages/*/dist packages/*/loader",
    "lint": "npm run build:core && npm run build:wrappers && tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@stencil/core": "^4.31.0",
    "@stencil/react-output-target": "^1.6.0",
    "@stencil/vue-output-target": "^0.14.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
